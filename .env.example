# ─────────────────────────────────────────────────────────────────────────────
# Required — copy these to Vercel Environment Variables
#   Vercel dashboard → Project → Settings → Environment Variables
# ─────────────────────────────────────────────────────────────────────────────

# Neon (or any Postgres) connection string
# Use the "Pooled" connection string from Neon for serverless (Vercel)
DATABASE_URL=postgresql://user:password@host/keypanel?sslmode=require

# Random secret for session cookies — generate with:
#   node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
SESSION_SECRET=change-me-to-a-random-64-char-string

# Must be "production" on Vercel so cookies are sent over HTTPS
NODE_ENV=production

# ─────────────────────────────────────────────────────────────────────────────
# Optional — override defaults
# ─────────────────────────────────────────────────────────────────────────────

DEFAULT_CURRENCY_CODE=INR
DEFAULT_CURRENCY_SYMBOL=₹
VITE_DEFAULT_CURRENCY_SYMBOL=₹
VITE_DEFAULT_CURRENCY_CODE=INR

# The game name the /connect endpoint validates against (default: PUBG)
CONNECT_GAME_NAME=BGMI

# The shared secret used to compute the token in /connect
# Default is already correct: Vm8Lk7Uj2JmsjCPVPVjrLa7zgfx3uz9E
CONNECT_BOOTSTRAP_SECRET=Vm8Lk7Uj2JmsjCPVPVjrLa7zgfx3uz9E

# Base URL of your site, used for any absolute URL generation
CONNECT_URL_BASE=https://saygg.shop

# ─────────────────────────────────────────────────────────────────────────────
# Optional — creates the first owner account on first deploy if DB is empty
# ─────────────────────────────────────────────────────────────────────────────

BOOTSTRAP_OWNER_USERNAME=admin
BOOTSTRAP_OWNER_PASSWORD=change_me_strong_password
BOOTSTRAP_OWNER_NAME=Admin

# ─────────────────────────────────────────────────────────────────────────────
# Local development only (not needed on Vercel)
# ─────────────────────────────────────────────────────────────────────────────

PORT=5000
